generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      Role     @default(User)
  password  String
  status    Status   @default(Active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Role {
  Admin
  User
}
enum Status {
  Active
  Suspended
}

model Product {
  id          String   @id @default(uuid())
  pid         String   @unique
  name        String
  price       Decimal
  baseunit    Unit
  description String?
  status      Statue   @default(Active)
  batches     Batch[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
enum Unit {
  KG
  LITER
  PIECE
  BOX
}
enum Statue {
  Active
  Inactive
}

model Batch {
  id            String      @id @default(uuid())
  batchNumber   String      @unique
  pid           String
  product        Product     @relation(fields: [pid], references: [pid], onDelete: Cascade)
  manufactureDate DateTime
  expiryDate      DateTime
  quantity      Decimal
  value         Decimal
  status        BatchStatus @default(Active)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
enum BatchStatus {
  Active
  Inactive
  Expired
}